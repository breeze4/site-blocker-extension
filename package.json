{
  "name": "site-blocker-extension",
  "version": "1.0.0",
  "description": "A Chrome extension for time-based website blocking with comprehensive usage analytics.",
  "private": true,
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "package": "node scripts/package.mjs",
    "format": "prettier --write 'src/**/*.js'",
    "format:check": "prettier --check 'src/**/*.js'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/breeze4/site-blocker-extension.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/breeze4/site-blocker-extension/issues"
  },
  "homepage": "https://github.com/breeze4/site-blocker-extension#readme",
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@testing-library/jest-dom": "^6.6.4",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "prettier": "^3.6.2"
  }
}
